# ──────────────────────────────────────────────────────────
# 密钥文件 — 绝不能 commit
# ──────────────────────────────────────────────────────────
# 上游 docker 部署密钥统一在 docker/.env,该文件本身在上游已被忽略

# ──────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ──────────────────────────────────────────────────────────
# 项目运行产物
# ──────────────────────────────────────────────────────────
output/
.cache/
*.log
*.db-journal

# 不要忽略 output 顶层的 .gitkeep (允许保留空目录)
!output/.gitkeep

# ──────────────────────────────────────────────────────────
# OS / IDE
# ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
