# ──────────────────────────────────────────────────────────
# 密钥文件 — 绝不能 commit
# ──────────────────────────────────────────────────────────
config/secrets.yaml

# 但保留模板文件,方便其他贡献者参考
!config/secrets.example.yaml

# ──────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ──────────────────────────────────────────────────────────
# 项目运行产物
# ──────────────────────────────────────────────────────────
output/
.cache/
*.log
*.db-journal

# 不要忽略 output 顶层的 .gitkeep (允许保留空目录)
!output/.gitkeep

# ──────────────────────────────────────────────────────────
# OS / IDE
# ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
